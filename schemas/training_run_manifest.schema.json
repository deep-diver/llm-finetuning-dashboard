{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TrainingRunManifest",
  "type": "object",
  "properties": {
    "run_id": { "type": "string" },
    "start_time": { "type": "string" },
    "end_time": { "type": "string" },
    "duration_seconds": { "type": "number" },
    "completed_steps": { "type": "integer" },
    "final_loss": { "type": "number" },
    "average_step_time_ms": { "type": "number" },
    "tpu_cores_used": { "type": "integer" },
    "logs_path": { "type": "string" },
    "checkpoint_directory": { "type": "string" },
    "success": { "type": "boolean" }
  },
  "required": ["run_id", "start_time", "completed_steps", "logs_path", "success"]
}
